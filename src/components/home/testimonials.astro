---
import testimonials from "../../collections/testimonials.json";
import Testimonial from "../testimonial.astro";
---

<section class="max-w-6xl mx-auto px-3 sm:px-7 lg:px-0 overflow-hidden mt-7 mb-12">
  <div class="relative w-full overflow-hidden">
    <!-- Gradient masks for smooth fade effect at edges -->
    <div class="absolute inset-y-0 left-0 w-12 sm:w-24 bg-gradient-to-r from-white to-transparent z-10 pointer-events-none"></div>
    <div class="absolute inset-y-0 right-0 w-12 sm:w-24 bg-gradient-to-l from-white to-transparent z-10 pointer-events-none"></div>

    <div class="flex w-max animate-marquee hover:pause-animation items-stretch py-4">
      {
        [...testimonials, ...testimonials].map((t) => (
          <div class="w-[350px] md:w-[550px] flex-shrink-0 mx-3 flex">
            <div class="w-full h-full">
              <Testimonial
                name={t.name}
                role={t.role}
                company={t.company}
                text={t.text}
              />
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .animate-marquee {
    animation: marquee 30s linear infinite;
  }
  .pause-animation {
    animation-play-state: paused;
  }
</style>

