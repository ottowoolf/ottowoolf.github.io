---
import testimonials from "../../collections/testimonials.json";
import Testimonial from "../testimonial.astro";
---

<section class="max-w-4xl mx-auto px-7 lg:px-0">
  <div class="grid items-stretch w-full grid-cols-1 md:grid-cols-2 gap-7 mt-7 mb-12">
    {
      testimonials.map((t) => (
        <Testimonial
          name={t.name}
          role={t.role}
          company={t.company}
          text={t.text}
        />
      ))
    }
  </div>
</section>
