---
const { title, description } = Astro.props;
---

<div class="relative z-20 w-full mx-auto lg:mx-0">
  <h2
    class="text-3xl font-bold tracking-tight text-neutral-900  sm:text-4xl lg:text-5xl"
  >
    {title}
  </h2>
  <p
    class="mt-3 text-base leading-6 text-neutral-600  sm:mt-4 lg:mt-6 sm:leading-7 lg:leading-4 sm:text-lg md:text-xl"
  >
    {description}
  </p>
</div>
