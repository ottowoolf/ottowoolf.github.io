---
import GameLayout from "../layouts/GameLayout.astro";
---

<GameLayout title="About Me (Game UI/UX)">
  <section class="relative z-20 max-w-5xl mx-auto my-24 px-7 lg:px-0 mt-32">
    
    <div class="mb-16 relative inline-block">
        <h1 class="p5-title text-6xl md:text-8xl font-black uppercase tracking-wider text-white relative z-10 drop-shadow-lg transform -rotate-1">
            <span class="inline-block transform rotate-2 text-white" style="-webkit-text-stroke: 2px black; text-shadow: -4px 4px 0 #e60012;">About</span> 
            <span style="-webkit-text-stroke: 2px black; text-shadow: 4px 4px 0 #e60012;">Me</span>
        </h1>
        <div class="absolute top-2 -right-12 bg-[#e60012] text-white font-black uppercase italic tracking-widest px-6 py-1 text-sm transform rotate-12 shadow-[0_4px_10px_rgba(0,0,0,0.5)] z-20 border-2 border-black">
            The Designer
        </div>
    </div>

    <div class="flex flex-col md:flex-row gap-12 relative">
        <!-- Left: Bio -->
        <div class="flex-1 relative drop-shadow-[0_0_15px_rgba(255,255,255,0.15)]">
            <div class="absolute inset-0 bg-[#e60012] transform translate-x-3 translate-y-4 p5-card-frame"></div>
            <div class="relative bg-black border-[6px] border-white p-10 p5-card-frame h-full">
                <p class="font-bold text-xl text-white leading-relaxed mb-6">
                    I specialize in creating immersive, intuitive, and accessible user interfaces for games. 
                </p>
                <p class="font-bold text-lg text-neutral-400 leading-relaxed">
                    My approach bridges the gap between player psychology and stunning visual design. Whether it's a frantic shooter HUD or a deep RPG inventory system, I focus on making the player's experience seamless and engaging.
                </p>
            </div>
        </div>

        <!-- Right: Skills -->
        <div class="flex-1 relative drop-shadow-[0_0_15px_rgba(255,255,255,0.15)]">
            <div class="absolute inset-0 bg-white transform translate-x-3 translate-y-4 p5-card-frame"></div>
            <div class="relative bg-black border-[6px] border-[#e60012] p-10 p5-card-frame h-full">
                <h3 class="p5-title text-3xl font-black text-[#e60012] uppercase tracking-wide mb-8">Skill Tree</h3>
                
                <ul class="space-y-4 font-bold text-lg text-white">
                    <li class="flex items-center gap-4">
                        <span class="w-4 h-4 bg-[#e60012] inline-block transform rotate-45 border-2 border-white"></span>
                        UI Flow & Wireframing
                    </li>
                    <li class="flex items-center gap-4">
                        <span class="w-4 h-4 bg-white inline-block transform rotate-45 border-2 border-[#e60012]"></span>
                        Iconography & Vector Art
                    </li>
                    <li class="flex items-center gap-4">
                        <span class="w-4 h-4 bg-[#e60012] inline-block transform rotate-45 border-2 border-white"></span>
                        Motion Graphics & UI Animation
                    </li>
                    <li class="flex items-center gap-4">
                        <span class="w-4 h-4 bg-white inline-block transform rotate-45 border-2 border-[#e60012]"></span>
                        Implementation (UMG / Unity)
                    </li>
                </ul>
            </div>
        </div>
    </div>
  </section>
</GameLayout>
