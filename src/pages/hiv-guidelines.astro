---
import Layout from "../layouts/main.astro";

const heroImage = "/assets/images/projects/hiv-guidelines-hero.png"; 
const megaMenuImg = "/assets/images/projects/megaMenu.gif";
const sideMenuImg = "/assets/images/projects/hiv-guidelines-side-menu.png";
const mobileImg = "/assets/images/projects/hiv-guidelines-mobile.png";
---

<Layout title="HIV Guidelines">
  <div class="w-full bg-white  transition-colors duration-300">
    <header class="relative h-[85vh] min-h-[600px] w-full flex items-center justify-center overflow-hidden bg-slate-900">
      <div class="absolute inset-0 bg-slate-900/50 z-10"></div>
      <img
        src={heroImage}
        alt="HIV Guidelines Hero"
        class="absolute inset-0 w-full h-full object-cover opacity-50 animate-slow-zoom"
        transition:name="project-image-/hiv-guidelines"
      />

      <div class="relative z-20 text-center max-w-5xl px-6 mt-20">
        <span class="inline-block py-1 px-3 rounded-full bg-white/10 border border-white/20 text-white text-xs font-bold uppercase tracking-widest mb-6 backdrop-blur-md">
          UX Design Case Study
        </span>
        <h6 class="text-4xl md:text-5xl font-black text-white mb-6 tracking-tight leading-tight">
          Consolidating the HIV Guidelines
        </h6>
        <p class="text-1xl md:text-2xl text-slate-200 max-w-3xl mx-auto leading-relaxed font-light">
          A unified knowledge base providing healthcare workers with access to all aspects of HIV treatment in one place.
        </p>
      </div>
    </header>

    <div class="border-b border-gray-100  bg-white ">
      <div class="max-w-6xl mx-auto px-6 py-12">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
          <div>
            <h3 class="text-xs font-bold text-gray-400  uppercase tracking-widest mb-2">Role</h3>
            <p class="font-medium text-gray-900 ">UX Designer</p>
          </div>
          <div>
            <h3 class="text-xs font-bold text-gray-400  uppercase tracking-widest mb-2">Timeline</h3>
            <p class="font-medium text-gray-900 ">3 months</p>
          </div>
          <div>
            <h3 class="text-xs font-bold text-gray-400  uppercase tracking-widest mb-2">Stack</h3>
            <div class="flex flex-wrap gap-2">
              <span class="px-2 py-1 bg-gray-100  rounded text-xs font-medium text-gray-600 ">Figma</span>
            </div>
          </div>
          <div class="flex items-center">
            <a
              href="https://hiv.guidelines.org.au/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center w-full py-3 bg-slate-900  text-white  rounded-xl font-bold hover:bg-black  transition-all text-sm group shadow-lg"
            >
              Visit Live Site
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-2 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform"><path d="M7 7h10v10"></path><path d="M7 17 17 7"></path></svg>
            </a>
          </div>
        </div>
      </div>
    </div>

    <div class="max-w-4xl mx-auto px-6 py-16 space-y-24">
      <section class="bg-indigo-50  rounded-2xl p-10 border border-indigo-50  relative overflow-hidden">
        <h4 class="text-xs font-bold text-indigo-500 uppercase tracking-widest mb-4 flex items-center gap-2">
          Project Effort & Scope
        </h4>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 relative z-10">
          <div>
            <span class="block text-4xl font-bold text-indigo-600  mb-2 tracking-tighter">7</span>
            <span class="text-sm text-indigo-900/100  font-medium leading-tight block">Distinct Guidelines Consolidated</span>
          </div>
          <div>
            <span class="block text-4xl font-bold text-indigo-600  mb-2 tracking-tighter">15</span>
            <span class="text-sm text-indigo-900/100  font-medium leading-tight block">In-Depth User Interviews</span>
          </div>
          <div>
            <span class="block text-4xl font-bold text-indigo-600  mb-2 tracking-tighter">90+</span>
            <span class="text-sm text-indigo-900/100  font-medium leading-tight block">Survey Responses Analysed</span>
          </div>
        </div>
      </section>

      <section>
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900  mb-8">
          The Challenge
        </h2>
        <p class="text-l text-gray-600  leading-relaxed mb-4">
          The primary objective of this project was to consolidate almost seven distinct HIV guidelines (covering topics like PEP, PrEP, Anal Cancer, and Adult ARV) into a single, unified experience. Previously, healthcare workers struggled to find the specific guidance they needed across fragmented resources.
        </p>
        <p class="text-l text-gray-600  leading-relaxed mb-4">
          I drove the end-to-end UX process, starting with intensive user research. By interviewing 15 health workers (including GPs, Nurses, Managers, and Educators) and gathering over 90 survey responses, I identified the core pain points in their information-seeking workflows.
        </p>
        <p class="text-l text-gray-600  leading-relaxed mb-12">
          A significant part of the challenge was <strong>Stakeholder Management</strong>. I was responsible for coordinating with various guideline bodies and project managing the design to ensure every group felt their specific needs were met within the new unified structure.
        </p>
      </section>

      <!-- The Solution -->
      <section>
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900  mb-8">
          The Solution
        </h2>

        <!-- 1. Mega Menu -->
        <div class="mb-16">
          <h3 class="text-1xl font-bold text-gray-900  mb-4">
            1. Global Mega Menu Navigation
          </h3>
          <p class="prose prose-l text-gray-600  mb-8 max-w-full">
            To ensure healthcare workers could quickly jump between different guidelines without getting lost, I designed a comprehensive Mega Menu. This acted as the global navigation, providing access to all crucial information from anywhere on the site, regardless of how deep into a specific guideline the user was.
          </p>
          <img src={megaMenuImg} alt="Mega Menu Navigation Design" class="max-w-full h-auto object-contain rounded-2xl border border-gray-200 " />
        </div>

        <!-- 2. Contextual Side Menus -->
        <div class="mb-16">
          <h3 class="text-1xl font-bold text-gray-900  mb-4">
            2. Bird's Eye View with Side Menus
          </h3>
          <p class="prose prose-l text-gray-600  mb-8 max-w-full">
            While the mega menu provided global reach, users still needed localized context. I implemented persistent side menus that provide a bird's eye view of all the information within the specific guideline or section they are currently browsing, significantly reducing cognitive load.
          </p>
          <img src={sideMenuImg} alt="Side Menu Design" class="max-w-full h-auto object-contain rounded-2xl border border-gray-200 " />
        </div>

        <!-- 3. Mobile Optimisation -->
        <div>
          <h3 class="text-1xl font-bold text-gray-900  mb-4">
            3. A Truly Mobile-Friendly Experience
          </h3>
          <p class="prose prose-l text-gray-600  mb-8 max-w-full">
            The original implementations of these guidelines were notoriously difficult to use on mobile devices. I completely overhauled the responsive behaviour, ensuring that complex tables, nested navigation, and dense medical text were highly readable and accessible on phones and tablets for workers on the go.
          </p>
          <img src={mobileImg} alt="Mobile Friendly Design" class="max-w-full h-auto object-contain rounded-2xl border border-gray-200 " />
        </div>
      </section>
    </div>
  </div>
</Layout>

<style>
  @keyframes slow-zoom {
    0% { transform: scale(1); }
    100% { transform: scale(1.05); }
  }
  .animate-slow-zoom {
    animation: slow-zoom 20s linear infinite alternate;
  }
</style>
