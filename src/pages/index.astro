<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dual Portfolio Concept</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Bangers&family=Open+Sans:wght@400;600;700;800&family=Figtree:wght@400;600;700;800&display=swap"
      rel="stylesheet"
    />
    <style>
      body,
      html {
        margin: 0;
        padding: 0;
        width: 100%;
        height: 100%;
        overflow: hidden;
        background-color: #111;
        font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
      }
      canvas {
        display: block;
        width: 100%;
        height: 100%;
        cursor: pointer;
      }
      #message {
        position: absolute;
        bottom: 20px;
        left: 50%;
        transform: translateX(-50%);
        color: white;
        background: rgba(0, 0, 0, 0.7);
        padding: 10px 20px;
        border-radius: 20px;
        font-size: 14px;
        pointer-events: none;
        opacity: 0;
        transition: opacity 0.3s;
      }
    </style>
  </head>
  <body>
    <canvas id="portfolioCanvas"></canvas>
    <div id="message">Click a side to enter...</div>

    <script is:inline>
      /** @type {HTMLCanvasElement | null} */
      const canvas = document.getElementById("portfolioCanvas");
      /** @type {HTMLDivElement | null} */
      const msg = document.getElementById("message");

      if (!canvas || !msg) {
        throw new Error("Portfolio canvas or message element was not found.");
      }

      const ctx = canvas.getContext("2d");

      if (!ctx) {
        throw new Error("2D canvas context is not available.");
      }

      const canvasEl = canvas;
      const msgEl = msg;
      const drawingContext = ctx;

      let width = 0;
      let height = 0;
      let progress = 0;
      let introDone = false;
      let hoverSide = null;

      // Transition variables
      let transitionPhase = "none"; // 'none', 'delay', 'slide', 'fadeOut'
      let transitionProgress = 0;
      let transitionStart = 0;
      const slideDuration = 800; // ms
      const fadeDuration = 700; // ms (slide + fade = 1500ms)

      // Easing functions
      const easeOutExpo = (x) => (x === 1 ? 1 : 1 - Math.pow(2, -10 * x));
      const easeInCubic = (x) => x * x * x;

      function resize() {
        width = canvasEl.width = window.innerWidth;
        height = canvasEl.height = window.innerHeight;
      }

      window.addEventListener("resize", resize);
      resize();

      // Track Mouse
      let mouse = { x: -1000, y: -1000 };
      window.addEventListener("mousemove", (e) => {
        if (transitionPhase !== "none") return; // Lock hover state during transition

        mouse.x = e.clientX;
        mouse.y = e.clientY;

        // Calculate split boundary at current Y
        const topX = width * 0.6;
        const bottomX = width * 0.4;
        const splitX = topX - (topX - bottomX) * (mouse.y / height);

        const prev = hoverSide;
        if (mouse.x < splitX) {
          hoverSide = "left";
        } else {
          hoverSide = "right";
        }

        // Update cursor only when hoverSide changes
        if (hoverSide !== prev) {
          if (hoverSide === "left") {
            // Use an inline data-URL SVG rendering of the 🎮 emoji for a crisp cursor
            const emojiSvg = `<svg xmlns='http://www.w3.org/2000/svg' width='64' height='64'><text x='50%' y='50%' dominant-baseline='middle' text-anchor='middle' font-size='48'>🎮</text></svg>`;
            const dataUrl = `url("data:image/svg+xml;utf8,${encodeURIComponent(emojiSvg)}") 32 32, auto`;
            canvasEl.style.cursor = dataUrl;
          } else {
            // Keep pointer cursor to indicate interactivity on the product side
            canvasEl.style.cursor = "pointer";
          }
        }
      });

      // Reset cursor when leaving the canvas
      canvasEl.addEventListener("mouseleave", () => {
        canvasEl.style.cursor = "default";
      });

      window.addEventListener("click", () => {
        if (introDone && hoverSide && transitionPhase === "none") {
          if (hoverSide === "right") {
            // Start the product transition with a delay
            transitionPhase = "delay";
            msgEl.innerText = "Redirecting to Product Design...";
            msgEl.style.opacity = "1";

            setTimeout(() => {
              transitionPhase = "slide";
              transitionStart = performance.now();
            }, 400); // 400ms delay before sliding
          } else {
            // Game side is coming soon
            msgEl.innerText = "Game Design Portfolio is Coming Soon!";
            msgEl.style.opacity = "1";
            setTimeout(() => (msgEl.style.opacity = "0"), 2000);
          }
        }
      });

      // Draw Manga Speed Lines
      /**
       * @param {CanvasRenderingContext2D} ctx
       * @param {number} x
       * @param {number} y
       * @param {number} radius
       * @param {string} color
       */
      function drawSpeedLines(ctx, x, y, radius, color) {
        ctx.save();
        ctx.translate(x, y);
        ctx.strokeStyle = color;
        ctx.lineWidth = 2;
        for (let i = 0; i < 40; i++) {
          const angle = Math.random() * Math.PI * 2;
          const length = radius + Math.random() * 200;
          ctx.beginPath();
          ctx.moveTo(Math.cos(angle) * radius, Math.sin(angle) * radius);
          ctx.lineTo(Math.cos(angle) * length, Math.sin(angle) * length);
          ctx.stroke();
        }
        ctx.restore();
      }

      // Draw text with extra spacing between words (in pixels)
      /**
       * @param {CanvasRenderingContext2D} ctx
       * @param {string} text
       * @param {number} x
       * @param {number} y
       * @param {number} extraWordSpacing
       */
      function drawTextWithWordSpacing(ctx, text, x, y, extraWordSpacing) {
        const words = text.split(" ");
        const spaceWidth = ctx.measureText(" ").width;
        const wordWidths = words.map((w) => ctx.measureText(w).width);
        const totalWidth =
          wordWidths.reduce((a, b) => a + b, 0) +
          (words.length - 1) * (spaceWidth + extraWordSpacing);

        const prevAlign = ctx.textAlign;
        // compute starting x based on alignment
        let startX = x;
        if (prevAlign === "center") startX = x - totalWidth / 2;
        else if (prevAlign === "right") startX = x - totalWidth;

        ctx.textAlign = "left";
        let cursor = startX;
        for (let i = 0; i < words.length; i++) {
          ctx.fillText(words[i], cursor, y);
          cursor += wordWidths[i] + spaceWidth + extraWordSpacing;
        }
        ctx.textAlign = prevAlign;
      }

      // Deterministic pseudo-random based on position — keeps halftone static
      function randFromPos(x, y) {
        return Math.abs(Math.sin(x * 12.9898 + y * 78.233) * 43758.5453) % 1;
      }

      function draw() {
        ctx.clearRect(0, 0, width, height);

        const easedProgress = easeOutExpo(progress);
        const isNarrow = width <= 600;

        // Base X coordinates and text positions
        let topX = width * 0.6;
        let bottomX = width * 0.4;
        let leftTextX = width * 0.25;
        let rightTextX = width * 0.75;

        // Handle Exit Transition Positions
        if (transitionPhase === "slide") {
          const t = easeInCubic(transitionProgress);
          topX -= width * 1.5 * t;
          bottomX -= width * 1.5 * t;
          leftTextX -= width * 1.5 * t;
          rightTextX = width * 0.75 - width * 0.25 * t; // Move to center
        } else if (transitionPhase === "fadeOut") {
          topX = -width;
          bottomX = -width;
          leftTextX = -width;
          rightTextX = width * 0.5; // Locked in center
        }

        // --- GLOBAL ZOOM (used for transition zoom) ---
        ctx.save();

        // If we're in the fade-out phase, apply a gentle zoom centered on the viewport
        if (transitionPhase === "fadeOut") {
          const cx = width * 0.5;
          const cy = height * 0.5;
          const scale = 1 + easeOutExpo(transitionProgress) * 0.35; // up to ~1.35x
          ctx.translate(cx, cy);
          ctx.scale(scale, scale);
          ctx.translate(-cx, -cy);
        }
        // Diagonal Slide offsets (Intro)
        const animInv = 1 - easedProgress;
        const leftOffsetX = -width * 0.5 * animInv;
        const leftOffsetY = height * 0.5 * animInv; // Starts bottom-left, moves up

        const rightOffsetX = width * 0.5 * animInv;
        const rightOffsetY = -height * 0.5 * animInv; // Starts top-right, moves down

        // --- DRAW LEFT SIDE (GAME DESIGN) ---
        drawingContext.save();
        drawingContext.translate(leftOffsetX, leftOffsetY);

        drawingContext.beginPath();
        drawingContext.moveTo(0, 0);
        drawingContext.lineTo(topX, 0);
        drawingContext.lineTo(bottomX, height);
        drawingContext.lineTo(0, height);
        drawingContext.closePath();

        // Fill
        drawingContext.fillStyle = hoverSide === "left" ? "#ff2a5f" : "#cc113f";
        drawingContext.fill();
        drawingContext.letterSpacing = "6px";

        // Halftone overlay (comic-style) clipped to the left polygon
        if (true) {
          drawingContext.save();
          drawingContext.clip();
          const active = hoverSide === "left";
          drawingContext.fillStyle = active
            ? "rgba(0,0,0,0.16)"
            : "rgba(0,0,0,0.06)";
          const step = active ? 18 : 28;
          const cx = leftTextX;
          const cy = height * 0.5;
          for (let y = -step; y < height + step; y += step) {
            for (let x = -step; x < width + step; x += step) {
              const dx = x - cx;
              const dy = y - cy;
              const dist = Math.sqrt(dx * dx + dy * dy);
              // dot size increases towards center
              const maxDist = Math.max(width, height);
              const t = Math.max(0, 1 - dist / maxDist);
              // slightly smaller maximum radii for a tighter halftone
              const base = active ? 5 : 2.5;
              const noise = randFromPos(x, y);
              const r = Math.max(0.5, base * t * (0.5 + noise * 0.6));
              drawingContext.beginPath();
              drawingContext.arc(x, y, r, 0, Math.PI * 2);
              drawingContext.fill();
            }
          }
          drawingContext.restore();
        }

        // Text (desktop vs narrow/mobile)
        drawingContext.fillStyle = "white";
        drawingContext.textAlign = "center";
        drawingContext.textBaseline = "middle";
        drawingContext.save();
        drawingContext.translate(leftTextX, height * 0.5);
        drawingContext.rotate(-0.1);

        // Subtle shadow that blends with the page background (#111)
        drawingContext.shadowColor = "rgba(17,17,17,0.75)";
        drawingContext.shadowBlur = 6;
        drawingContext.shadowOffsetX = 2;
        drawingContext.shadowOffsetY = 2;
        if (isNarrow) {
          const basePx = Math.floor(Math.min(width, height) * 0.11);
          const mainPx = Math.max(12, Math.min(44, basePx - 12));
          drawingContext.font = `900 italic ${mainPx}px Bangers`;
          const halfGap = 2; // total gap = 4px (2px above, 2px below)
          drawingContext.fillText("GAME", 0, 0); // single-line title on narrow

          drawingContext.font = `800 italic ${Math.max(12, Math.floor(mainPx * 0.35))}px Bangers`;
          drawingContext.fillStyle = "#ffeb3b";
          drawingContext.letterSpacing = "6px";
          drawTextWithWordSpacing(
            drawingContext,
            "- COMING SOON -",
            0,
            Math.floor(mainPx / 2) + 28,
            4,
          );
        } else {
          drawingContext.font = "900 italic 4vw Bangers";
          drawingContext.fillText("GAME", 0, -35);
          drawingContext.fillText("DESIGN", 0, 20);

          drawingContext.font = "800 italic 1.5vw Arial";
          drawingContext.fillStyle = "#ffeb3b";
          drawTextWithWordSpacing(drawingContext, "- COMING SOON -", 0, 65, 4);
        }
        drawingContext.restore();

        // Speed lines during intro
        if (!introDone)
          drawSpeedLines(
            drawingContext,
            0,
            height / 2,
            100,
            "rgba(255,255,255,0.3)",
          );

        drawingContext.restore();

        // --- DRAW RIGHT SIDE (ENTERPRISE) ---
        drawingContext.save();
        drawingContext.translate(rightOffsetX, rightOffsetY);

        drawingContext.beginPath();
        drawingContext.moveTo(topX, 0);
        drawingContext.lineTo(width, 0);
        drawingContext.lineTo(width, height);
        drawingContext.lineTo(bottomX, height);
        drawingContext.closePath();

        // Fill
        drawingContext.fillStyle =
          hoverSide === "right" ? "#0077ff" : "#0055b3";
        drawingContext.fill();

        // Grid pattern (Enterprise feel)
        if (hoverSide === "right") {
          drawingContext.strokeStyle = "rgba(255, 255, 255, 0.1)";
          drawingContext.lineWidth = 1;
          for (let i = 0; i < width; i += 40) {
            drawingContext.beginPath();
            drawingContext.moveTo(i, 0);
            drawingContext.lineTo(i, height);
            drawingContext.stroke();
          }
          for (let i = 0; i < height; i += 40) {
            drawingContext.beginPath();
            drawingContext.moveTo(0, i);
            drawingContext.lineTo(width, i);
            drawingContext.stroke();
          }
        }

        // Text (desktop vs narrow/mobile)
        drawingContext.fillStyle = "white";
        drawingContext.textAlign = "center";
        drawingContext.textBaseline = "middle";
        drawingContext.save();
        drawingContext.translate(rightTextX, height * 0.5);
        if (isNarrow) {
          const basePxR = Math.floor(Math.min(width, height) * 0.11);
          const mainPxR = Math.max(12, Math.min(44, basePxR - 12));
          drawingContext.font = `900 ${mainPxR}px Figtree`;
          drawingContext.fillText("PRODUCT", 0, 0);
        } else {
          drawingContext.font = "900 4vw Figtree";
          drawingContext.fillText("PRODUCT", 0, -30);
          drawingContext.fillText("DESIGN", 0, 30);
        }
        drawingContext.restore();

        // Speed lines during intro
        if (!introDone)
          drawSpeedLines(
            drawingContext,
            width,
            height / 2,
            100,
            "rgba(255,255,255,0.3)",
          );

        drawingContext.restore();

        // --- DRAW CENTER SPLIT LINE ---
        if (introDone) {
          drawingContext.beginPath();
          drawingContext.moveTo(topX, 0);
          drawingContext.lineTo(bottomX, height);
          drawingContext.strokeStyle = "#fff";
          drawingContext.lineWidth = 10;
          drawingContext.stroke();

          // Black manga-style border next to white line
          drawingContext.beginPath();
          drawingContext.moveTo(topX - 6, 0);
          drawingContext.lineTo(bottomX - 6, height);
          drawingContext.strokeStyle = "#000";
          drawingContext.lineWidth = 4;
          drawingContext.stroke();
        }

        drawingContext.restore(); // Restore from global zoom

        // --- FADE TO WHITE ---
        if (transitionPhase === "fadeOut") {
          drawingContext.fillStyle = `rgba(255, 255, 255, ${transitionProgress})`;
          drawingContext.fillRect(0, 0, width, height);
        }

        // Animation logic (time-based for consistent durations)
        const now = performance.now();
        if (transitionPhase === "slide") {
          const t = Math.min(1, (now - transitionStart) / slideDuration);
          transitionProgress = t;
          if (t >= 1) {
            transitionPhase = "fadeOut";
            transitionStart = now;
            transitionProgress = 0;
          }
        } else if (transitionPhase === "fadeOut") {
          const t = Math.min(1, (now - transitionStart) / fadeDuration);
          transitionProgress = t;
          if (t >= 1) {
            window.location.href = "/product";
            return;
          }
        } else if (progress < 1) {
          progress += 0.009; // Intro animation slower
        } else if (!introDone) {
          introDone = true;
          msgEl.style.opacity = "1";
          setTimeout(() => (msgEl.style.opacity = "0"), 2000);
        }

        requestAnimationFrame(draw);
      }

      // Start
      setTimeout(() => {
        draw();
      }, 300);
    </script>
  </body>
</html>
